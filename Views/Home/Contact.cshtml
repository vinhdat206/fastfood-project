@model FastFood.Models.ContactMessage

@{
    ViewData["Title"] = "Liên hệ";
}

<div class="container mt-5">

    <h1 class="text-center mb-3">📞 Liên hệ FastFood</h1>

    <p class="text-center text-muted mb-5">
        Chúng tôi luôn sẵn sàng hỗ trợ bạn. Hãy gửi câu hỏi hoặc góp ý cho chúng tôi!
    </p>

    <div class="row">

        <!-- CONTACT INFO -->
        <div class="col-md-5">
            <div class="card shadow-sm p-4 h-100">

                <h4 class="mb-4">📍 Thông tin cửa hàng</h4>

                <p>
                    <b>Địa chỉ:</b><br>
                    123 FastFood Street<br>
                    Ha Noi City
                </p>

                <p>
                    <b>📞 Điện thoại:</b><br>
                    0123 456 789
                </p>

                <p>
                    <b>✉ Email:</b><br>
                    fastfood@gmail.com
                </p>

                <p>
                    <b>🕒 Giờ mở cửa:</b><br>
                    08:00 - 22:00 mỗi ngày
                </p>

            </div>
        </div>

        <!-- CONTACT FORM -->
        <div class="col-md-7">
            <div class="card shadow-sm p-4">

                <h4 class="mb-4">📩 Gửi tin nhắn</h4>

                @if(ViewBag.Success != null)
                {
                    <div class="alert alert-success">
                        @ViewBag.Success
                    </div>
                }

                <form asp-controller="Home" asp-action="Contact" method="post">

                    <div class="mb-3">
                        <label class="form-label">Họ và tên</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên của bạn">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="Nhập email">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nội dung</label>
                        <textarea asp-for="Message" class="form-control" rows="4" placeholder="Nhập nội dung liên hệ"></textarea>
                    </div>

                    <button type="submit" class="btn btn-danger w-100">
                        Gửi liên hệ
                    </button>

                </form>

            </div>
        </div>

    </div>
</div>

<!-- GOOGLE MAP -->

<div class="container mt-5 mb-5">
    <div class="card shadow-sm">

        <iframe
            width="100%"
            height="350"
            style="border:0"
            loading="lazy"
            allowfullscreen
            src="https://maps.google.com/maps?q=ha%20noi&t=&z=13&ie=UTF8&iwloc=&output=embed">
        </iframe>

    </div>
</div>