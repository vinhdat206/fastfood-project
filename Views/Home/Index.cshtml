@model IEnumerable<FastFood.Models.Food>
@using System.Linq
@section Styles{
    <link rel="stylesheet" href="~/css/user/home.css" />
}
@{
    ViewData["Title"] = "Trang chủ";

    var bestSeller = ViewBag.BestSeller as List<Food> ?? new List<Food>();
    var saleProducts = ViewBag.SaleProducts as List<Food> ?? new List<Food>();

    Random rand = new Random();
}

<!-- ================= BANNER ================= -->

<div class="banner mb-4">
    <img src="~/images/banners/banner-new.png" class="img-fluid w-100">
</div>


<!-- ================= BEST SELLER ================= -->
<div class="container mt-5">

    <h2 class="text-center mb-4">🔥 Sản phẩm bán chạy</h2>

    <div class="row">

        @foreach (var item in bestSeller)
        {
            <div class="col-lg-3 col-md-4 col-6 mb-4">

                <div class="card product-card shadow-sm">

                    <div class="product-img">

                        <!-- FIX IMAGE -->
                        <img src="@Url.Content(item.Image)"
                             
                             onclick="openFood(@item.FoodId)"
                             style="cursor:pointer">

                    </div>

                    <hr class="product-divider">

                    <div class="card-body text-center">

                        <h6>@item.FoodName</h6>

                        @if(item.DiscountPercent > 0)
                        {
                            <p>

                                <span class="text-muted text-decoration-line-through">
                                    @item.Price.ToString("N0") đ
                                </span>

                                <span class="text-danger fw-bold">
                                    @item.DiscountPrice.ToString("N0") đ
                                </span>

                            </p>
                        }
                        else
                        {
                            <p class="text-danger fw-bold">
                                @item.Price.ToString("N0") đ
                            </p>
                        }

                        <button class="buy-now-btn"
                                onclick="openFood(@item.FoodId)">
                            Mua ngay →
                        </button>

                    </div>

                </div>

            </div>
        }

    </div>

</div>


<!-- ================= SALE PRODUCTS ================= -->

<div class="container mt-5">

    <h2 class="text-center mb-4 text-danger">
        🔥 Khuyến mãi hôm nay
    </h2>

    <div class="row">

        @foreach (var item in bestSeller.Take(4))
        {
            int percent = rand.Next(10, 30);

            decimal salePrice = item.Price - (item.Price * percent / 100);

            <div class="col-lg-3 col-md-4 col-6 mb-4">

                <div class="card product-card shadow-sm">

                    <span class="sale-badge">SALE</span>

                    <span class="discount-badge">
                        -@percent%
                    </span>

                    <div class="product-img">

                        <img src="@Url.Content(item.Image)"
                             onclick="openFood(@item.FoodId)"
                             style="cursor:pointer">

                    </div>

                    <hr class="product-divider">

                    <div class="card-body text-center">

                        <h6>@item.FoodName</h6>

                        <p>

                            <span class="text-muted text-decoration-line-through">
                                @item.Price.ToString("N0") đ
                            </span>

                            <span class="text-danger fw-bold">
                                @salePrice.ToString("N0") đ
                            </span>

                        </p>

                        <button class="buy-now-btn"
                                onclick="openFood(@item.FoodId)">
                            Mua ngay →
                        </button>

                    </div>

                </div>

            </div>
        }

    </div>

</div>


<!-- ================= COMBO ================= -->

<div class="container mt-5">

    <h2 class="text-center mb-4 text-danger">
        🍔 Combo ưu đãi
    </h2>

    <div class="row">

        @foreach (var item in bestSeller.Take(4))
        {
            int percent = rand.Next(5, 20);

            decimal comboPrice = item.Price - (item.Price * percent / 100);

            <div class="col-lg-3 col-md-4 col-6 mb-4">

                <div class="card product-card shadow-sm">

                    <span class="combo-badge">COMBO</span>

                    <span class="discount-badge">
                        -@percent%
                    </span>

                    <div class="product-img">

                        <img src="@Url.Content(item.Image)"
                             
                             onclick="openFood(@item.FoodId)"
                             style="cursor:pointer">

                    </div>

                    <hr class="product-divider">

                    <div class="card-body text-center">

                        <h6>Combo @item.FoodName</h6>

                        <p>

                            <span class="text-muted text-decoration-line-through">
                                @item.Price.ToString("N0") đ
                            </span>

                            <span class="text-success fw-bold">
                                @comboPrice.ToString("N0") đ
                            </span>

                        </p>

                        <button class="buy-now-btn"
                                onclick="openFood(@item.FoodId)">
                            Mua combo →
                        </button>

                    </div>

                </div>

            </div>
        }

    </div>

</div>


<!-- ================= REVIEW ================= -->

<div class="container mt-5">

    <h2 class="text-center mb-4">⭐ Khách hàng nói gì</h2>

    <div class="row">

        <div class="col-md-4">

            <div class="card shadow-sm p-3">
                <p>Đồ ăn rất ngon, burger nóng giòn và phục vụ nhanh!</p>
                <strong>Nguyễn Minh</strong>
            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm p-3">
                <p>Pizza cực kỳ chất lượng, sẽ quay lại lần sau.</p>
                <strong>Trần Huy</strong>
            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm p-3">
                <p>Giá hợp lý, combo rất đáng tiền.</p>
                <strong>Lê Hoàng</strong>
            </div>

        </div>

    </div>

</div>

<!--POPUP-->


<!-- POPUP MODAL -->
<div class="modal fade" id="foodModal" tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-body" id="foodModalBody">
            </div>

        </div>

    </div>

</div>

<div id="toastBox" class="toast-box"></div>

<script>

function openFood(id){

fetch('/Home/FoodDetail/' + id)

.then(res => res.text())

.then(html => {

document.getElementById("foodModalBody").innerHTML = html;

var modal = new bootstrap.Modal(
document.getElementById('foodModal')
);

modal.show();

});

}
function changeQty(num){

    let qtyInput = document.getElementById("qty");

    if(!qtyInput) return;

    let qty = parseInt(qtyInput.value);

    qty += num;

    if(qty < 1) qty = 1;

    qtyInput.value = qty;

    updatePrice();

}

function updatePrice(){

    let priceElement = document.getElementById("foodPrice");

    if(!priceElement) return;

    let basePrice = parseFloat(priceElement.dataset.price); // giá gốc

    let qty = parseInt(document.getElementById("qty").value);

    let total = basePrice * qty; // luôn tính lại từ giá gốc

    document.getElementById("totalPrice").innerText =
        total.toLocaleString('vi-VN') + " đ";

}
function addToCart(id) {

    let qtyInput = document.getElementById("qty");
    let qty = qtyInput ? qtyInput.value : 1;

    let noteInput = document.getElementById("note");
    let note = noteInput ? noteInput.value : "";

    fetch('/Cart/AddToCart?id=' + id + '&qty=' + qty + '&note=' + encodeURIComponent(note))
        .then(response => {

            if (response.redirected) {

                showToast("⚠️ Bạn cần đăng nhập để mua hàng");

                // đóng popup sản phẩm
                var foodModal = bootstrap.Modal.getInstance(document.getElementById('foodModal'));
                if(foodModal){
                    foodModal.hide();
                }

                // mở popup login
                setTimeout(()=>{
                    openLogin();
                },300);

                return;
            }

            if(response.ok){

                showToast("✅ Đã thêm vào giỏ hàng");

                updateCartCount();

            }

        });
}


function updateCartCount(qty){

    let cart = document.getElementById("cartCount");

    if(cart){

        let current = parseInt(cart.innerText) || 0;

        cart.innerText = current + parseInt(qty);

    }

}


function showToast(message){

    var toast = document.createElement("div");

    toast.className = "toast-msg";

    toast.innerText = message;

    document.getElementById("toastBox").appendChild(toast);

    setTimeout(()=>{
        toast.remove();
    },3000);

}

</script>