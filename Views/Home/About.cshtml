@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="container mt-5">

    <!-- TITLE -->
    <h1 class="text-center mb-4">Giới thiệu về FastFood</h1>

    <!-- BANNER -->
    <img src="~/images/Abouts/about1.png"
         class="img-fluid rounded w-100 mb-4">


    <!-- INTRO -->
    <p>
        FastFood là website đặt đồ ăn nhanh trực tuyến mang đến những món ăn
        ngon, tiện lợi và nhanh chóng. Chúng tôi phục vụ các món ăn phổ biến
        như burger, pizza, gà rán, khoai tây chiên và nhiều món hấp dẫn khác.
    </p>

    <p>
        Với mong muốn mang lại trải nghiệm tốt nhất cho khách hàng,
        FastFood luôn chú trọng đến chất lượng món ăn, dịch vụ giao hàng
        nhanh chóng và giá cả hợp lý.
    </p>


    <!-- STORY -->
    <h3 class="mt-5">Câu chuyện của chúng tôi</h3>

    <p>
        FastFood được tạo ra với mục tiêu giúp mọi người có thể đặt đồ ăn
        nhanh chóng chỉ với vài cú click. Chúng tôi tin rằng đồ ăn ngon
        không chỉ là hương vị mà còn là trải nghiệm.
    </p>


    <!-- IMAGE SECTION -->

    <div class="row mt-4">

        <div class="col-md-4">
            <img src="~/images/Abouts/about2.png" class="img-fluid rounded shadow">
        </div>

        <div class="col-md-4">
            <img src="~/images/Abouts/about3.png" class="img-fluid rounded shadow">
        </div>

        <div class="col-md-4">
            <img src="~/images/Abouts/about4.png" class="img-fluid rounded shadow">
        </div>

    </div>


    <!-- VALUES -->

    <h3 class="mt-5">Cam kết của chúng tôi</h3>

    <div class="row mt-3">

        <div class="col-md-4">
            <div class="card p-3 shadow-sm">
                <h5>🍔 Nguyên liệu tươi</h5>
                <p>Chúng tôi sử dụng nguyên liệu chất lượng để đảm bảo hương vị.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow-sm">
                <h5>⚡ Phục vụ nhanh</h5>
                <p>Đặt món nhanh chóng và giao hàng trong thời gian ngắn.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow-sm">
                <h5>💰 Giá hợp lý</h5>
                <p>Nhiều chương trình khuyến mãi hấp dẫn cho khách hàng.</p>
            </div>
        </div>

    </div>

</div>