@{
    Layout = null;
}



   

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
    background:none;
    height:auto;
    display:block;
}

/* Card */

.login-card{
    width:100%;
    max-width:420px;
    margin:auto;
}

.login-card h1{
font-size:28px;
margin-bottom:10px;
}

.login-card p{
color:#777;
margin-bottom:30px;
}

/* input */

.input-group{
position:relative;
margin-bottom:20px;
}

.input-group input{

width:100%;
padding:14px 40px 14px 14px;

border-radius:10px;
border:1px solid #ddd;

font-size:15px;

}

.input-group i{

position:absolute;
right:12px;
top:50%;
transform:translateY(-50%);
color:#999;

}

/* remember */

.options{
display:flex;
justify-content:space-between;
align-items:center;
font-size:14px;
margin-bottom:20px;
}

.options a{
text-decoration:none;
color:#6c63ff;
}

/* button */

.login-btn{

width:100%;
padding:14px;
border:none;

border-radius:10px;

background:linear-gradient(90deg,#5f8df6,#7c4dff);

color:white;
font-size:16px;

cursor:pointer;
margin-bottom:20px;

}

.login-btn:hover{
opacity:0.9;
}

/* divider */

.divider{
margin:15px 0;
color:#999;
font-size:14px;
}

/* social */

.social{

display:flex;
gap:15px;
margin-bottom:20px;

}

.social button{

flex:1;
padding:10px;

border-radius:10px;
border:1px solid #ddd;
background:white;

cursor:pointer;

}

.social button i{
margin-right:6px;
}

/* register */

.register{
font-size:14px;
}

.register a{
color:#5f8df6;
text-decoration:none;
font-weight:bold;
}
.modal-content{
    border-radius:15px;
}

.modal-body{
    padding:30px;
}
</style>



<div class="login-card">

    <h1>Chào mừng trở lại!</h1>
    <p>Vui lòng đăng nhập vào tài khoản của bạn</p>

    <form method="post" asp-controller="Account" asp-action="Login">

        <div class="input-group">
            <input type="text" name="Email" placeholder="Email hoặc số điện thoại">
            <i class="fa fa-envelope"></i>
        </div>

        <div class="input-group">
            <input type="password" name="Password" placeholder="Mật khẩu">
            <i class="fa fa-lock"></i>
        </div>

        <div class="options">

            <label>
                <input type="checkbox"> Ghi nhớ đăng nhập
            </label>

            <a href="#">Quên mật khẩu?</a>

        </div>

        <button class="login-btn">
            Đăng Nhập
        </button>

    </form>

    <div class="divider">
        Hoặc đăng nhập với
    </div>

    <div class="social">

        <button>
            <i class="fab fa-facebook"></i>
            Facebook
        </button>

        <button>
            <i class="fab fa-google"></i>
            Google
        </button>

    </div>

    <div class="register">

        Chưa có tài khoản?
        <a href="#" onclick="openRegister()">Đăng ký ngay</a>

    </div>

</div>



<script>
let returnUrl = sessionStorage.getItem("returnUrl");

if(returnUrl){
    sessionStorage.removeItem("returnUrl");
    window.location.href = returnUrl;
}
</script>