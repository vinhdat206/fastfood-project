@using Newtonsoft.Json
@using FastFood.Models
<!DOCTYPE html>
<html lang="vi">

<head>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>@ViewData["Title"] - FastFood</title>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

<link rel="stylesheet" href="~/css/site.css" />
<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
@RenderSection("Styles", required: false)

</head>
<div id="toastBox" class="toast-box"></div>
<body>

<!-- NAVBAR -->

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">

<div class="container">

<!-- LOGO -->

<a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
   <img src="~/images/Logo/Logo.PNG" alt="FastFood Logo" style="height:50px ; margin-right:8px;">
   <span class="fw-bold text-danger">FastFood</span>
</a>

<button class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav">

<span class="navbar-toggler-icon"></span>

</button>

<div class="collapse navbar-collapse" id="navbarNav">

<!-- MENU -->

<ul class="navbar-nav mx-auto main-menu">

   <li class="nav-item">
      <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString()=="Home" 
                         && ViewContext.RouteData.Values["Action"]?.ToString()=="Index" ? "active-menu" : "")"
         asp-controller="Home" asp-action="Index">
         Trang chủ
      </a>
   </li>

   <li class="nav-item">
      <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString()=="About" ? "active-menu" : "")"
         asp-controller="Home" asp-action="About">
         Giới thiệu
      </a>
   </li>

   <li class="nav-item dropdown">

      <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString()=="Menu" ? "active-menu" : "")"
         asp-controller="Menu" asp-action="Index">
         Sản phẩm
      </a>

      <a class="nav-link "
         href="#"
         data-bs-toggle="dropdown">
      </a>

      <ul class="dropdown-menu">

         <li>
            <a class="dropdown-item" asp-controller="Menu" asp-action="Burger">🍔 Burger</a>
         </li>

         <li>
            <a class="dropdown-item" asp-controller="Menu" asp-action="Pizza">🍕 Pizza</a>
         </li>

         <li>
            <a class="dropdown-item" asp-controller="Menu" asp-action="Chicken">🍗 Gà rán</a>
         </li>

         <li>
            <a class="dropdown-item" asp-controller="Menu" asp-action="Drink">🥤 Đồ uống</a>
         </li>

         <li>
            <a class="dropdown-item" asp-controller="Menu" asp-action="Combo">🍟 Combo</a>
         </li>

      </ul>

   </li>

   <li class="nav-item">
      <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString()=="Contact" ? "active-menu" : "")"
         asp-controller="Home" asp-action="Contact">
         Liên hệ
      </a>
   </li>

   <li class="nav-item">
      <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString()=="Policy" ? "active-menu" : "")"
         asp-controller="Home" asp-action="Policy">
         Chính sách
      </a>
   </li>

</ul>


<!-- RIGHT SIDE -->

<!-- RIGHT SIDE -->
<div class="d-flex align-items-center">

   <!-- SEARCH -->
   <form class="search-box me-3">
      <input type="text" placeholder="Tìm món..." />
      <button type="submit">🔍</button>
   </form>

   <!-- CART -->
   <a asp-controller="Cart" asp-action="Index" class="cart-icon me-3">
      🛒
      <span id="cartCount" class="cart-count">
         @(Context.Session.GetString("Cart") == null ? 0 :
            Newtonsoft.Json.JsonConvert.DeserializeObject<List<CartItem>>
               (Context.Session.GetString("Cart")).Sum(x => x.Quantity))
      </span>
   </a>

   <!-- ACCOUNT -->
   <!-- ACCOUNT -->
   <div class="dropdown ms-2">
      <a class="nav-link" href="#" id="accountDropdown" role="button" data-bs-toggle="dropdown">
         <i class="fas fa-user-circle fs-5"></i>
      </a>

      <ul class="dropdown-menu">

         @if (Context.Session.GetString("UserEmail") == null)
         {
            <li>
               <a class="dropdown-item" href="#" onclick="openLogin()">Login</a>
            </li>

            <li>
               <a class="dropdown-item" href="#" onclick="openRegister()">Register</a>
            </li>
         }
         else
         {
            <li>
               <span class="dropdown-item text-danger">
                  👤 @Context.Session.GetString("UserEmail")
               </span>
            </li>

            <li>
               <a class="dropdown-item" href="/Order/History"> Lịch sử đơn</a>
            </li>

            <li>
               <a class="dropdown-item" href="/Account/Logout">Logout</a>
            </li>
         }

      </ul>
   </div>

</div>

</div>

</div>

</nav>


<!-- CONTENT -->

<div class="container mt-4">

@RenderBody()

</div>


<!-- FOOTER -->

<footer class="bg-dark text-white text-center mt-5 p-4">

<p>© 2026 FastFood Restaurant</p>

<p>Email: fastfood@gmail.com | Phone: 0123456789</p>

</footer>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@RenderSection("Scripts", required: false)
<!-- LOGIN MODAL -->
<div class="modal fade" id="loginModal" tabindex="-1">
   <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content p-3">

         <div class="modal-header">
            <h5 class="modal-title">Đăng nhập</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
         </div>

         <div class="modal-body" id="loginModalBody"></div>

      </div>
   </div>
</div>

<!-- REGISTER MODAL -->
<div class="modal fade" id="registerModal" tabindex="-1">
   <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content p-3">

         <div class="modal-header">
            <h5 class="modal-title">Đăng ký</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
         </div>

         <div class="modal-body" id="registerModalBody"></div>

      </div>
   </div>
</div>
</body>
<script>

function openLogin() {

   fetch('/Account/Login')
      .then(res => res.text())
      .then(html => {

         document.getElementById("loginModalBody").innerHTML = html;

         var modal = new bootstrap.Modal(document.getElementById('loginModal'));

         modal.show();

      });
}



function openRegister(){

   fetch('/Account/Register')
      .then(res => res.text())
      .then(html => {

         document.getElementById("registerModalBody").innerHTML = html;

         var modal = new bootstrap.Modal(document.getElementById('registerModal'));

         modal.show();

      });

}
</script>
